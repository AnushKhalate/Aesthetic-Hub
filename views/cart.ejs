<%- include("./partials/header") %>
<%- include("./partials/navbar") %>

<div class="container py-5">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <h1 class="fw-bold">
            <i class="ri-shopping-cart-2-line"></i>
            My Cart
        </h1>

        <a href="/shop" class="btn btn-outline-dark">
            <i class="ri-arrow-left-line"></i>
            Continue Shopping
        </a>

    </div>

    <% if(cart && cart.length > 0){ %>

    <div class="row">

        <div class="col-lg-8">

            <% cart.forEach(function(item){ %>

            <div class="card shadow-sm mb-4">

                <div class="row g-0 align-items-center">

                    <div class="col-md-3 text-center p-3">

                        <img
                            src="data:image/jpeg;base64,<%= item.image.toString('base64') %>"
                            class="img-fluid"
                            style="height:150px;object-fit:contain;"
                        >

                    </div>

                    <div class="col-md-9">

                        <div class="card-body">

                            <div class="d-flex justify-content-between">

                                <div>

                                    <h4 class="fw-bold">
                                        <%= item.name %>
                                    </h4>

                                    <h5 class="text-danger">
                                        ₹ <%= item.price %>
                                    </h5>

                                    <span class="badge bg-success">
                                        In Stock
                                    </span>

                                </div>

                                <div class="text-end">

                                    <p class="mb-2">
                                        Qty :
                                        <strong>1</strong>
                                    </p>

                                    <form
                                        action="/removeCart/<%= item._id %>"
                                        method="POST"
                                    >

                                        <button
                                            class="btn btn-outline-danger"
                                            type="submit"
                                        >

                                            <i class="ri-delete-bin-line"></i>
                                            Remove

                                        </button>

                                    </form>

                                </div>

                            </div>

                        </div>

                    </div>

                </div>

            </div>

            <% }) %>

        </div>

        <div class="col-lg-4">

            <div class="card shadow sticky-top">

                <div class="card-body">

                    <h3 class="fw-bold mb-4">
                        Order Summary
                    </h3>

                    <div class="d-flex justify-content-between mb-3">

                        <span>Total Items</span>
  
                     <strong>
                            <%= cart.length %>
                        </strong>

                    </div>

                    <div class="d-flex justify-content-between mb-3">

                        <span>Shipping</span>

                        <strong class="text-success">
                            FREE
                        </strong>

                    </div>

                    <hr>

                    <div class="d-flex justify-content-between">

                        <h4>Total</h4>

                        <h4 class="text-danger">
                            ₹ <%= total %>
                        </h4>

                    </div>

                   <a
    href="/checkout"
    class="btn btn-warning w-100 mt-4 py-3 fw-bold"
>
    <i class="ri-bank-card-line"></i>
    Proceed to Checkout
</a>

                </div>

            </div>

        </div>

    </div>

    <% } else { %>

    <div class="card shadow text-center p-5">

        <i
            class="ri-shopping-cart-line"
            style="font-size:90px;color:#6c757d;"
        ></i>

        <h2 class="mt-4">
            Your cart is empty
        </h2>

        <p class="text-muted">

            Looks like you haven't added any products yet.

        </p>

        <a
            href="/shop"
            class="btn btn-warning btn-lg mt-3"
        >

            Continue Shopping

        </a>

    </div>

    <% } %>

</div>

<%- include("./partials/footer") %>