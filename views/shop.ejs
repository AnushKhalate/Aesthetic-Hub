<%- include('./partials/header') %>
<%- include("./partials/navbar") %>

<div class="container-fluid bg-light py-5">
       <% if (typeof success !== "undefined" && success.length > 0) { %>
        <div class="alert alert-success alert-dismissible fade show text-center mb-4">
            <%= success %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    <% } %>

       <% if (typeof error !== "undefined" && error.length > 0) { %>
        <div class="alert alert-danger alert-dismissible fade show text-center mb-4">
            <%= error %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    <% } %>

    <!-- Hero Section -->
    <div class="container mb-5">

        <div class="bg-dark text-white rounded-4 p-5 shadow">

            <div class="row align-items-center">

                <div class="col-md-8">

                    <h1 class="display-4 fw-bold">
                        Scatch Store
                    </h1>

                    <p class="lead mb-4">
                        Premium Collection for Every Style.
                    </p>

                    <a href="#products" class="btn btn-warning btn-lg">
                        Shop Now
                    </a>

                </div>

                <div class="col-md-4 text-md-end mt-4 mt-md-0">

                    <h3 class="fw-bold">
                        <%= products ? products.length : 0 %> Products
                    </h3>

                </div>

            </div>

        </div>

    </div>

    <div class="container">

        <div class="row g-4">


            <!-- Product Section -->
            <div class="col-lg-9">

                <div
                    class="d-flex justify-content-between align-items-center mb-4"
                    id="products"
                >

                    <h2 class="fw-bold mb-0">
                         Products
                    </h2>
               
               </div>

                <% if (products && products.length > 0) { %>

                    <div class="row g-4">

                        <% products.forEach(function(product) { %>

                            <div class="col-md-6 col-xl-4">

                                <div class="card shadow border-0 rounded-4 h-100 overflow-hidden">

                                    <!-- Product Image -->
                                    <div
                                        class="d-flex justify-content-center align-items-center bg-white p-3"
                                        style="height:260px;"
                                    >

                                        <% if (product.image) { %>

                                            <img
                                                src="data:image/jpeg;base64,<%= product.image.toString('base64') %>"
                                                class="img-fluid"
                                                style="
                                                    max-height:220px;
                                                    max-width:100%;
                                                    object-fit:contain;
                                                "
                                                alt="<%= product.name %>"
                                            >

                                        <% } else { %>

                                            <span class="text-muted">
                                                No image available
                                            </span>

                                        <% } %>

                                    </div>

                                    <!-- Product Details -->
                                    <div class="card-body p-4">

                                        <h5 class="fw-bold mb-2">
                                            <%= product.name %>
                                        </h5>

                                        <h3 class="text-danger fw-bold mb-3">
                                            ₹ <%= product.price %>
                                        </h3>

                                        <% if (product.discount) { %>

                                            <span class="badge bg-success fs-6">
                                                <%= product.discount %>% OFF
                                            </span>

                                        <% } %>

                                    </div>

                                    <!-- Add To Cart -->
                                    <div class="card-footer bg-white border-0 p-4 pt-0">

                                        <form
                                            action="/addCart/<%= product._id %>"
                                            method="post"
                                        >

                                            <button
                                                type="submit"
                                                class="btn btn-dark w-100 py-2"
                                            >
                                                <i class="ri-shopping-cart-line"></i>
                                                Add To Cart
                                            </button>

                                        </form>

                                    </div>

                                </div>

                            </div>

                        <% }) %>

                    </div>

                <% } else { %>

                    <div class="alert alert-warning text-center rounded-4 py-5">

                        <h3 class="fw-bold">
                            No Products Available
                        </h3>

                        <p class="mb-0">
                            Add products from the admin panel.
                        </p>

                    </div>

                <% } %>

            </div>

        </div>

    </div>

</div>

<%- include('./partials/footer') %>