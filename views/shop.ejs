<%- include("./partials/header") %>
<%- include("./partials/navbar") %>

<div class="container-fluid bg-light store-page py-5">

    <div class="container">

        <% if (
            typeof success !== "undefined" &&
            success &&
            success.length > 0
        ) { %>

            <div class="alert alert-success alert-dismissible fade show shadow-sm">

                <i class="ri-checkbox-circle-line me-2"></i>

                <%= Array.isArray(success) ? success[0] : success %>

                <button
                    type="button"
                    class="btn-close"
                    data-bs-dismiss="alert"
                ></button>

            </div>

        <% } %>

        <% if (
            typeof error !== "undefined" &&
            error &&
            error.length > 0
        ) { %>

            <div class="alert alert-danger alert-dismissible fade show shadow-sm">

                <i class="ri-error-warning-line me-2"></i>

                <%= Array.isArray(error) ? error[0] : error %>

                <button
                    type="button"
                    class="btn-close"
                    data-bs-dismiss="alert"
                ></button>

            </div>

        <% } %>

        <!-- Hero -->

        <section class="store-hero mb-5">

            <div class="row align-items-center g-4">

                <div class="col-lg-8">

                    <h1 class="store-hero-title mb-3">
                        Scatch Store
                    </h1>

                    <p class="store-hero-text mb-4">
                        Premium Collection for Every Style.
                    </p>

                    <a
                        href="#products"
                        class="btn btn-warning btn-lg fw-semibold"
                    >
                        Shop Now
                    </a>

                </div>

                <div class="col-lg-4 text-lg-end">

                    <h3 class="fw-bold mb-0">
                        <%= products ? products.length : 0 %> Products
                    </h3>

                </div>

            </div>

        </section>

        <div class="row g-4">

           

           

            <!-- Products -->

            <main class="col-lg-9">

                <div
                    id="products"
                    class="d-flex justify-content-between align-items-center mb-4"
                >

                    <h2 class="fw-bold mb-0">
                        Products
                    </h2>



                </div>

                <% if (products && products.length > 0) { %>

                    <div class="row g-4">

                        <% products.forEach(function(product) { %>

                            <div class="col-12 col-sm-6 col-xl-4">

                                <div class="card product-card shadow-sm">

                                    <div class="product-image-wrapper">

                                        <% if (product.image) { %>

                                            <img
                                                src="data:image/jpeg;base64,<%= product.image.toString('base64') %>"
                                                class="product-image"
                                                alt="<%= product.name %>"
                                            >

                                        <% } else { %>

                                            <div class="text-center text-muted">

                                                <i
                                                    class="ri-image-line"
                                                    style="font-size: 50px;"
                                                ></i>

                                                <p class="mb-0">
                                                    No image
                                                </p>

                                            </div>

                                        <% } %>

                                    </div>

                                    <div class="card-body p-4">

                                        <h5 class="fw-bold mb-2">
                                            <%= product.name %>
                                        </h5>

                                        <h3 class="text-danger fw-bold mb-3">
                                            ₹<%= Number(product.price || 0).toLocaleString("en-IN") %>
                                        </h3>

                                        <% if (Number(product.discount) > 0) { %>

                                            <span class="badge bg-success">
                                                <%= product.discount %>% OFF
                                            </span>

                                        <% } %>

                                    </div>

                                    <div class="card-footer bg-white border-0 p-4 pt-0">

                                        <form
                                            action="/addCart/<%= product._id %>"
                                            method="POST"
                                        >

                                            <button
                                                type="submit"
                                                class="btn btn-dark w-100 py-2 fw-semibold"
                                            >
                                                <i class="ri-shopping-cart-line me-1"></i>
                                                Add To Cart
                                            </button>

                                        </form>

                                    </div>

                                </div>

                            </div>

                        <% }) %>

                    </div>

                <% } else { %>

                    <div class="card shadow-sm text-center">

                        <div class="card-body p-5">

                            <i
                                class="ri-shopping-bag-3-line text-muted"
                                style="font-size: 75px;"
                            ></i>

                            <h3 class="fw-bold mt-3">
                                No Products Available
                            </h3>

                            <p class="text-muted mb-0">
                                Products added by the admin will appear here.
                            </p>

                        </div>

                    </div>

                <% } %>

            </main>

        </div>

    </div>

</div>

<%- include("./partials/footer") %>