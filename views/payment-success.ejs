<%- include("./partials/header") %>
<%- include("./partials/navbar") %>

<div class="container py-5">

    <div class="row justify-content-center">

        <div class="col-lg-7">

            <div class="card border-0 shadow-lg text-center">

                <div class="card-body p-5">

                    <div
                        class="bg-success text-white rounded-circle d-flex align-items-center justify-content-center mx-auto mb-4"
                        style="width: 100px; height: 100px;"
                    >
                        <i
                            class="ri-check-line"
                            style="font-size: 55px;"
                        ></i>
                    </div>

                    <h1 class="fw-bold">
                        Payment Successful
                    </h1>

                    <p class="text-muted fs-5">
                        Thank you for shopping with Scatch Store.
                    </p>

                    <div class="bg-light rounded-4 p-4 my-4 text-start">

                        <div class="d-flex justify-content-between mb-3">
                            <span>Order ID</span>

                            <strong>
                                <%= order._id %>
                            </strong>
                        </div>

                        <div class="d-flex justify-content-between mb-3">
                            <span>Payment ID</span>

                            <strong>
                                <%= order.razorpayPaymentId %>
                            </strong>
                        </div>

                        <div class="d-flex justify-content-between">
                            <span>Total paid</span>

                            <strong class="text-success">
                                ₹<%= Number(order.totalAmount).toLocaleString("en-IN") %>
                            </strong>
                        </div>

                    </div>

                    <a href="/shop" class="btn btn-warning px-4 py-3">
                        Continue Shopping
                    </a>

                    <a
                        href="/account"
                        class="btn btn-outline-dark px-4 py-3 ms-2"
                    >
                        My Account
                    </a>

                </div>

            </div>

        </div>

    </div>

</div>

<%- include("./partials/footer") %>