<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0"
    >

    <title>Login | Scatch</title>

    <link
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css"
        rel="stylesheet"
    >
</head>

<body class="bg-light">

<div class="container-fluid min-vh-100">

    <div class="row min-vh-100 g-0">

        <!-- Left Brand Section -->
        <div class="col-lg-6 d-none d-lg-flex">

            <div
                class="w-100 d-flex flex-column justify-content-center text-white p-5"
                style="background:#212529;"
            >

                <div class="px-xl-5">

                    <span class="badge bg-warning text-dark fs-6 px-3 py-2 mb-4">
                        SCATCH STORE
                    </span>

                    <h1 class="display-3 fw-bold mb-3">
                        Welcome back
                    </h1>

                    <p class="fs-4 text-light mb-5">
                        Login to continue exploring products designed for every style.
                    </p>

                    <div class="d-flex align-items-center mb-4">

                        <div
                            class="bg-warning text-dark rounded-circle d-flex align-items-center justify-content-center me-3"
                            style="width:50px;height:50px;font-size:22px;"
                        >
                            ✓
                        </div>

                        <div>

                            <h5 class="fw-bold mb-1">
                                Secure Login
                            </h5>

                            <p class="text-light mb-0">
                                Your account information is safely protected.
                            </p>

                        </div>

                    </div>

                    <div class="d-flex align-items-center mb-4">

                        <div
                            class="bg-warning text-dark rounded-circle d-flex align-items-center justify-content-center me-3"
                            style="width:50px;height:50px;font-size:22px;"
                        >
                            ✓
                        </div>

                        <div>

                            <h5 class="fw-bold mb-1">
                                Quick Access
                            </h5>

                            <p class="text-light mb-0">
                                Access your account and products instantly.
                            </p>

                        </div>

                    </div>

                    <div class="d-flex align-items-center">

                        <div
                            class="bg-warning text-dark rounded-circle d-flex align-items-center justify-content-center me-3"
                            style="width:50px;height:50px;font-size:22px;"
                        >
                            ✓
                        </div>

                        <div>

                            <h5 class="fw-bold mb-1">
                                Premium Collection
                            </h5>

                            <p class="text-light mb-0">
                                Discover high-quality products in one place.
                            </p>

                        </div>

                    </div>

                </div>

            </div>

        </div>

        <!-- Login Form Section -->
        <div class="col-lg-6">

            <div class="d-flex align-items-center justify-content-center min-vh-100 p-4">

                <div style="width:100%;max-width:520px;">

                    <div class="mb-4">

                        <h2 class="display-6 fw-bold text-dark mb-2">
                            Login to Scatch
                        </h2>

                        <p class="text-muted fs-5 mb-0">
                            Enter your account details to continue.
                        </p>

                    </div>

                    <% if (typeof error !== "undefined" && error.length > 0) { %>

                        <div
                            class="alert alert-danger border-0 shadow-sm rounded-3"
                            role="alert"
                        >
                            <strong>Login failed:</strong>
                            <%= error %>
                        </div>

                    <% } %>

                    <div class="card border-0 shadow-lg rounded-4">

                        <div class="card-body p-4 p-md-5">

                            <form action="/users/login" method="POST">

                                <div class="mb-4">

                                    <label
                                        for="email"
                                        class="form-label fw-semibold"
                                    >
                                        Email Address
                                    </label>

                                    <div class="input-group input-group-lg">

                                        <span class="input-group-text bg-white">
                                            ✉
                                        </span>

                                        <input
                                            type="email"
                                            id="email"
                                            name="email"
                                            class="form-control"
                                            placeholder="Enter your email"
                                            autocomplete="email"
                                            required
                                        >

                                    </div>

                                </div>

                                <div class="mb-3">

                                    <label
                                        for="password"
                                        class="form-label fw-semibold"
                                    >
                                        Password
                                    </label>

                                    <div class="input-group input-group-lg">

                                        <span class="input-group-text bg-white">
                                            🔒
                                        </span>

                                        <input
                                            type="password"
                                            id="password"
                                            name="password"
                                            class="form-control"
                                            placeholder="Enter your password"
                                            autocomplete="current-password"
                                            required
                                        >

                                        <button
                                            type="button"
                                            class="btn btn-outline-secondary"
                                            id="togglePassword"
                                        >
                                            Show
                                        </button>

                                    </div>

                                </div>

                                <div class="d-flex justify-content-between align-items-center mb-4">

                                    <div class="form-check">

                                        <input
                                            class="form-check-input"
                                            type="checkbox"
                                            id="rememberMe"
                                        >

                                        <label
                                            class="form-check-label"
                                            for="rememberMe"
                                        >
                                            Remember me
                                        </label>

                                    </div>

                                </div>

                                <div class="d-grid mb-4">

                                    <button
                                        type="submit"
                                        class="btn btn-warning btn-lg fw-semibold py-3"
                                    >
                                        Login
                                    </button>

                                </div>

                            </form>

                            <div class="position-relative my-4">

                                <hr>

                                <span
                                    class="position-absolute top-50 start-50 translate-middle bg-white px-3 text-muted"
                                >
                                    New to Scatch?
                                </span>

                            </div>

                            <div class="d-grid">

                                <a
                                    href="/"
                                    class="btn btn-outline-dark btn-lg py-3"
                                >
                                    Create a new account
                                </a>

                            </div>

                        </div>

                    </div>

                    <p class="text-center text-muted small mt-4 mb-0">
                        Secure access to your Scatch account.
                    </p>

                </div>

            </div>

        </div>

    </div>

</div>

<script>
    const passwordInput = document.getElementById("password");
    const togglePassword = document.getElementById("togglePassword");

    togglePassword.addEventListener("click", function () {
        const isPassword = passwordInput.type === "password";

        passwordInput.type = isPassword ? "text" : "password";
        togglePassword.textContent = isPassword ? "Hide" : "Show";
    });
</script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js"></script>

</body>

</html>