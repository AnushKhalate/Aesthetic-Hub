<%- include("./partials/header") %>
<%- include("./partials/navbar") %>

<div class="container py-5">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h1 class="fw-bold mb-1">
                <i class="ri-file-list-3-line me-2"></i>
                Order Details
            </h1>

            <p class="text-muted mb-0">
                Complete information about your order.
            </p>
        </div>

        <a href="/my-orders" class="btn btn-outline-dark">
            <i class="ri-arrow-left-line me-1"></i>
            Back to My Orders
        </a>

    </div>

    <div class="row g-4">

        <div class="col-lg-8">

            <div class="card border-0 shadow-sm">

                <div class="card-header bg-dark text-white p-4">

                    <div class="row g-3 align-items-center">

                        <div class="col-md-6">

                            <small class="text-white-50 d-block">
                                Order ID
                            </small>

                            <strong>
                                <%= order._id %>
                            </strong>

                        </div>

                        <div class="col-md-3">

                            <small class="text-white-50 d-block">
                                Order Date
                            </small>

                            <strong>
                                <%= new Date(order.createdAt).toLocaleDateString("en-IN", {
                                    day: "2-digit",
                                    month: "short",
                                    year: "numeric"
                                }) %>
                            </strong>

                        </div>

                        <div class="col-md-3 text-md-end">

                            <small class="text-white-50 d-block">
                                Order Status
                            </small>

                            <span class="badge bg-warning text-dark px-3 py-2">
                                <%= order.orderStatus || "placed" %>
                            </span>

                        </div>

                    </div>

                </div>

                <div class="card-body p-4">

                    <h4 class="fw-bold mb-4">
                        Products
                    </h4>

                    <% if (order.products && order.products.length > 0) { %>

                        <% order.products.forEach(function(item, index) { %>

                            <div
                                class="row align-items-center py-3 <%= index !== order.products.length - 1 ? 'border-bottom' : '' %>"
                            >

                                <div class="col-md-8">

                                    <div class="d-flex align-items-center">

                                        <div
                                            class="bg-light rounded-3 d-flex align-items-center justify-content-center me-3"
                                            style="width: 75px; height: 75px;"
                                        >
                                            <i
                                                class="ri-shopping-bag-3-line text-muted"
                                                style="font-size: 34px;"
                                            ></i>
                                        </div>

                                        <div>

                                            <h5 class="fw-bold mb-1">
                                                <%= item.name %>
                                            </h5>

                                            <p class="text-muted mb-0">
                                                Quantity: 1
                                            </p>

                                        </div>

                                    </div>

                                </div>

                                <div class="col-md-4 text-md-end mt-3 mt-md-0">

                                    <small class="text-muted d-block">
                                        Price
                                    </small>

                                    <h5 class="fw-bold mb-0">
                                        ₹<%= Number(item.price).toLocaleString("en-IN") %>
                                    </h5>

                                </div>

                            </div>

                        <% }) %>

                    <% } else { %>

                        <div class="alert alert-warning mb-0">
                            Product information is unavailable.
                        </div>

                    <% } %>

                </div>

            </div>

        </div>

        <div class="col-lg-4">

            <div class="card border-0 shadow-sm mb-4">

                <div class="card-body p-4">

                    <h4 class="fw-bold mb-4">
                        Payment Summary
                    </h4>

                    <div class="d-flex justify-content-between mb-3">
                        <span class="text-muted">
                            Payment Status
                        </span>

                        <% if (order.paymentStatus === "paid") { %>

                            <span class="badge bg-success">
                                Paid
                            </span>

                        <% } else if (order.paymentStatus === "failed") { %>

                            <span class="badge bg-danger">
                                Failed
                            </span>

                        <% } else { %>

                            <span class="badge bg-warning text-dark">
                                Pending
                            </span>

                        <% } %>
                    </div>

                    <div class="d-flex justify-content-between mb-3">
                        <span class="text-muted">
                            Number of Products
                        </span>

                        <strong>
                            <%= order.products ? order.products.length : 0 %>
                        </strong>
                    </div>

                    <div class="d-flex justify-content-between mb-3">
                        <span class="text-muted">
                            Shipping
                        </span>

                        <strong class="text-success">
                            Free
                        </strong>
                    </div>

                    <hr>

                    <div class="d-flex justify-content-between align-items-center">

                        <h5 class="fw-bold mb-0">
                            Total Paid
                        </h5>

                        <h3 class="fw-bold text-danger mb-0">
                            ₹<%= Number(order.totalAmount).toLocaleString("en-IN") %>
                        </h3>

                    </div>

                </div>

            </div>

            <div class="card border-0 shadow-sm">

                <div class="card-body p-4">

                    <h5 class="fw-bold mb-4">
                        Payment Information
                    </h5>

                    <div class="mb-3">
                        <small class="text-muted d-block">
                            Razorpay Order ID
                        </small>

                        <span class="text-break">
                            <%= order.razorpayOrderId || "Not available" %>
                        </span>
                    </div>

                    <div class="mb-3">
                        <small class="text-muted d-block">
                            Razorpay Payment ID
                        </small>

                        <span class="text-break">
                            <%= order.razorpayPaymentId || "Not available" %>
                        </span>
                    </div>

                    <div>
                        <small class="text-muted d-block">
                            Payment Date
                        </small>

                        <span>
                            <%= new Date(order.updatedAt || order.createdAt).toLocaleString("en-IN") %>
                        </span>
                    </div>

                </div>

            </div>

        </div>

    </div>

</div>

<%- include("./partials/footer") %>