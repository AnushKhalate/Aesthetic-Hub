<%- include("./partials/header") %>
<%- include("./partials/admin-navbar") %>

<div class="container py-5">

    <% if(success && success.length){ %>
        <div class="alert alert-success alert-dismissible fade show shadow-sm">
            <i class="ri-checkbox-circle-line me-2"></i>
            <%= success[0] %>

            <button class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    <% } %>

    <% if(error && error.length){ %>
        <div class="alert alert-danger alert-dismissible fade show shadow-sm">
            <i class="ri-error-warning-line me-2"></i>
            <%= error[0] %>

            <button class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    <% } %>

    <!-- Heading -->

    <div class="d-flex justify-content-between align-items-center mb-5">

        <div>

            <h1 class="fw-bold mb-1">
                Create Product
            </h1>

            <p class="text-muted mb-0">
                Add a new product to your Scatch Store.
            </p>

        </div>

        <a href="/owners/admin" class="btn btn-outline-dark">
            <i class="ri-arrow-left-line"></i>
            Dashboard
        </a>

    </div>

    <form
        action="/products/create"
        method="POST"
        enctype="multipart/form-data"
    >

        <div class="row g-4">

            <!-- Left Side -->

            <div class="col-lg-8">

                <!-- Product Information -->

                <div class="card border-0 shadow-sm mb-4">

                    <div class="card-header bg-dark text-white py-3">

                        <h5 class="mb-0">
                            Product Information
                        </h5>

                    </div>

                    <div class="card-body p-4">

                        <div class="mb-4">

                            <label class="form-label fw-semibold">
                                Product Name
                            </label>

                            <input
                                type="text"
                                name="name"
                                class="form-control form-control-lg"
                                placeholder="Enter product name"
                                required
                            >

                        </div>

                        <div class="row">

                            <div class="col-md-6 mb-4">

                                <label class="form-label fw-semibold">
                                    Price
                                </label>

                                <div class="input-group">

                                    <span class="input-group-text">
                                        ₹
                                    </span>

                                    <input
                                        type="number"
                                        name="price"
                                        class="form-control form-control-lg"
                                        placeholder="0"
                                        required
                                    >

                                </div>

                            </div>

                            <div class="col-md-6 mb-4">

                                <label class="form-label fw-semibold">
                                    Discount (%)
                                </label>

                                <div class="input-group">

                                    <input
                                        type="number"
                                        name="discount"
                                        value="0"
                                        class="form-control form-control-lg"
                                    >

                                    <span class="input-group-text">
                                        %
                                    </span>

                                </div>

                            </div>

                        </div>

                    </div>

                </div>

                <!-- Image Upload -->

                <div class="card border-0 shadow-sm">

                    <div class="card-header bg-dark text-white py-3">

                        <h5 class="mb-0">
                            Product Image
                        </h5>

                    </div>

                    <div class="card-body p-5">

                        <div
                            class="border border-2 border-dashed rounded-4 text-center p-5"
                        >

                            <img
                                id="preview"
                                src="https://placehold.co/300x250?text=Preview"
                                class="img-fluid mb-4"
                                style="max-height:250px;"
                            >

                            <input
                                type="file"
                                name="image"
                                id="image"
                                class="form-control"
                                accept="image/*"
                                required
                            >

                            <small class="text-muted d-block mt-3">
                                JPG, PNG or WEBP
                            </small>

                        </div>

                    </div>

                </div>

            </div>

            <!-- Right Side -->

            <div class="col-lg-4">

                <!-- Publish -->

                <div class="card border-0 shadow-sm mb-4">

                    <div class="card-header bg-warning">

                        <h5 class="mb-0 fw-bold">
                            Publish
                        </h5>

                    </div>

                    <div class="card-body">

                        <div class="mb-4">

                            <label class="form-label fw-semibold">
                                Product Status
                            </label>

                            <select
                                class="form-select"
                                name="status"
                            >

                                <option value="active">
                                    Active
                                </option>

                                <option value="draft">
                                    Draft
                                </option>

                            </select>

                        </div>

                        <button
                            class="btn btn-warning w-100 py-3 fw-bold"
                        >

                            <i class="ri-add-circle-line me-2"></i>

                            Create Product

                        </button>

                    </div>

                </div>

                <!-- Tips -->

                <div class="card border-0 shadow-sm">

                    <div class="card-body">

                        <h5 class="fw-bold mb-3">
                            Tips
                        </h5>

                        <ul class="small text-muted">

                            <li>
                                Upload a high-quality image.
                            </li>

                            <li>
                                Use a descriptive product name.
                            </li>

                            <li>
                                Add discounts only during offers.
                            </li>

                            <li>
                                Keep prices updated.
                            </li>

                        </ul>

                    </div>

                </div>

            </div>

        </div>

    </form>

</div>

<script>

const image=document.getElementById("image");
const preview=document.getElementById("preview");

image.addEventListener("change",function(){

    const file=this.files[0];

    if(file){

        preview.src=URL.createObjectURL(file);

    }

});

</script>

<style>

body{

    background:#f8f9fa;

}

.card{

    border-radius:18px;

}

.card-header{

    border-radius:18px 18px 0 0 !important;

}

.form-control,
.form-select{

    border-radius:12px;

}

.btn{

    border-radius:12px;

}

.border-dashed{

    border-style:dashed !important;

}

</style>

<%- include("./partials/footer") %>