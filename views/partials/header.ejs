<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0"
    >

    <title>Scatch Store</title>

    <!-- Bootstrap -->
    <link
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css"
        rel="stylesheet"
    >

    <!-- Remix Icons -->
    <link
        href="https://cdn.jsdelivr.net/npm/remixicon@4.6.0/fonts/remixicon.css"
        rel="stylesheet"
    >

    <!-- Google Font -->
    <link
        href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap"
        rel="stylesheet"
    >

    <style>

        * {
            box-sizing: border-box;
            font-family: "Poppins", sans-serif;
        }

        html,
        body {
            width: 100%;
            min-height: 100%;
            margin: 0;
            overflow-x: hidden;
        }

        body {
            background: #f8f9fa;
            color: #212529;
        }

        img {
            max-width: 100%;
            height: auto;
        }

        a {
            text-decoration: none;
        }

        .btn {
            border-radius: 12px;
        }

        .card {
            border: none;
            border-radius: 18px;
        }

        .rounded-4 {
            border-radius: 18px !important;
        }

        .form-control,
        .form-select,
        .input-group-text {
            border-radius: 10px;
        }

        .input-group {
            flex-wrap: nowrap;
        }

        .input-group .form-control {
            min-width: 0;
        }

        /* Navbar */

        .main-navbar {
            background: #111827;
            padding: 14px 0;
        }

        .main-navbar .navbar-brand {
            color: #ffc107 !important;
            font-size: 1.9rem;
            font-weight: 800;
            letter-spacing: 0.3px;
        }

        .main-navbar .nav-link {
            color: #ffffff !important;
            font-weight: 600;
            padding: 10px 14px !important;
            border-radius: 10px;
            transition: 0.2s ease;
        }

        .main-navbar .nav-link:hover {
            color: #ffc107 !important;
            background: rgba(255, 255, 255, 0.08);
        }

        .main-navbar .logout-btn {
            font-weight: 700;
            padding: 10px 18px;
            margin-left: 10px;
        }

        /* Hero */

        .store-hero {
            background: #212529;
            color: #ffffff;
            padding: 55px;
            border-radius: 20px;
            box-shadow: 0 12px 30px rgba(0, 0, 0, 0.14);
        }

        .store-hero-title {
            font-size: 3.5rem;
            font-weight: 800;
            line-height: 1.1;
        }

        .store-hero-text {
            font-size: 1.2rem;
            color: #e9ecef;
        }

        /* Product cards */

        .product-card {
            height: 100%;
            overflow: hidden;
            transition: 0.25s ease;
        }

        .product-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 14px 30px rgba(0, 0, 0, 0.14) !important;
        }

        .product-image-wrapper {
            height: 260px;
            padding: 18px;
            background: #ffffff;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .product-image {
            width: 100%;
            height: 100%;
            object-fit: contain;
        }

        /* Authentication pages */

        .auth-page {
            min-height: 100vh;
            background: #f8f9fa;
        }

        .auth-branding {
            min-height: 100vh;
            background: #212529;
            color: #ffffff;
            display: flex;
            align-items: center;
            padding: 60px;
        }

        .auth-branding-content {
            width: 100%;
            max-width: 650px;
            margin: auto;
        }

        .auth-form-section {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 45px;
        }

        .auth-form-wrapper {
            width: 100%;
            max-width: 520px;
        }

        .auth-card {
            border-radius: 20px;
            box-shadow: 0 15px 40px rgba(0, 0, 0, 0.12);
        }

        .auth-icon-box {
            width: 52px;
            min-width: 52px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .feature-icon {
            width: 50px;
            height: 50px;
            min-width: 50px;
            background: #ffc107;
            color: #212529;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 22px;
            font-weight: 700;
        }

        /* Responsive */

        @media (max-width: 991.98px) {

            .main-navbar .navbar-collapse {
                padding-top: 16px;
            }

            .main-navbar .navbar-nav {
                width: 100%;
                align-items: stretch !important;
            }

            .main-navbar .nav-item {
                width: 100%;
                margin: 0 !important;
            }

            .main-navbar .nav-link {
                width: 100%;
                text-align: left;
                margin-bottom: 4px;
            }

            .main-navbar .logout-btn {
                width: 100%;
                margin: 8px 0 0;
            }

            .auth-form-section {
                min-height: auto;
                padding: 45px 20px;
            }

        }

        @media (max-width: 767.98px) {

            .store-hero {
                padding: 35px 25px;
            }

            .store-hero-title {
                font-size: 2.4rem;
            }

            .store-hero-text {
                font-size: 1rem;
            }

            .sidebar-card {
                margin-bottom: 10px;
            }

        }

        @media (max-width: 575.98px) {

            body {
                font-size: 14px;
            }

            .container {
                padding-left: 15px;
                padding-right: 15px;
            }

            .main-navbar .navbar-brand {
                font-size: 1.5rem;
            }

            .store-page {
                padding-top: 25px !important;
                padding-bottom: 30px !important;
            }

            .store-hero {
                padding: 30px 22px;
                border-radius: 16px;
            }

            .store-hero-title {
                font-size: 2rem;
            }

            .store-hero .btn-lg {
                font-size: 1rem;
                padding: 11px 18px;
            }

            .product-image-wrapper {
                height: 230px;
            }

            .card-body {
                padding: 20px !important;
            }

            .auth-form-section {
                padding: 30px 14px;
            }

            .auth-form-wrapper {
                max-width: 100%;
            }

            .auth-form-wrapper h1,
            .auth-form-wrapper h2 {
                font-size: 2rem !important;
            }

            .auth-form-wrapper .fs-5 {
                font-size: 1rem !important;
            }

            .auth-card .card-body {
                padding: 24px 18px !important;
            }

            .auth-icon-box {
                width: 48px;
                min-width: 48px;
            }

            .form-control-lg,
            .input-group-lg > .form-control,
            .input-group-lg > .input-group-text,
            .input-group-lg > .btn {
                font-size: 1rem;
                padding: 12px;
            }

            .password-toggle {
                padding-left: 12px;
                padding-right: 12px;
                white-space: nowrap;
            }

        }

    </style>

</head>

<body>