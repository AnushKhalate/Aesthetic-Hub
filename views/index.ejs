<%- include("./partials/header") %>

<div class="container-fluid auth-page p-0">

    <div class="row g-0">

        <!-- Desktop branding -->

        <div class="col-lg-6 d-none d-lg-block">

            <div class="auth-branding">

                <div class="auth-branding-content">

                    <span class="badge bg-warning text-dark fs-6 px-3 py-2 mb-4">
                        SCATCH STORE
                    </span>

                    <h1 class="display-3 fw-bold mb-3">
                        Create your account
                    </h1>

                    <p class="fs-4 text-light mb-5">
                        Join Scatch and explore premium products made for every style.
                    </p>

                    <div class="d-flex align-items-center mb-4">

                        <div class="feature-icon me-3">
                            ✓
                        </div>

                        <div>

                            <h5 class="fw-bold mb-1">
                                Simple Registration
                            </h5>

                            <p class="text-light mb-0">
                                Create your account in a few seconds.
                            </p>

                        </div>

                    </div>

                    <div class="d-flex align-items-center mb-4">

                        <div class="feature-icon me-3">
                            ✓
                        </div>

                        <div>

                            <h5 class="fw-bold mb-1">
                                Secure Access
                            </h5>

                            <p class="text-light mb-0">
                                Your account details remain protected.
                            </p>

                        </div>

                    </div>

                    <div class="d-flex align-items-center">

                        <div class="feature-icon me-3">
                            ✓
                        </div>

                        <div>

                            <h5 class="fw-bold mb-1">
                                Better Shopping
                            </h5>

                            <p class="text-light mb-0">
                                Discover products and manage your experience.
                            </p>

                        </div>

                    </div>

                </div>

            </div>

        </div>

        <!-- Form -->

        <div class="col-lg-6">

            <div class="auth-form-section">

                <div class="auth-form-wrapper">

                    <div class="mb-4">

                        <h2 class="display-6 fw-bold mb-2">
                            Create Account
                        </h2>

                        <p class="text-muted fs-5 mb-0">
                            Enter your information to get started.
                        </p>

                    </div>

                    <% if (
                        typeof error !== "undefined" &&
                        error &&
                        error.length > 0
                    ) { %>

                        <div class="alert alert-danger shadow-sm">

                            <strong>
                                Registration failed:
                            </strong>

                            <%= Array.isArray(error) ? error[0] : error %>

                        </div>

                    <% } %>

                    <% if (
                        typeof success !== "undefined" &&
                        success &&
                        success.length > 0
                    ) { %>

                        <div class="alert alert-success shadow-sm">

                            <%= Array.isArray(success) ? success[0] : success %>

                        </div>

                    <% } %>

                    <div class="card auth-card">

                        <div class="card-body p-4 p-md-5">

                            <form action="/users/register" method="POST">

                                <div class="mb-4">

                                    <label
                                        for="fullname"
                                        class="form-label fw-semibold"
                                    >
                                        Full Name
                                    </label>

                                    <div class="input-group input-group-lg">

                                        <span class="input-group-text bg-white auth-icon-box">
                                            <i class="ri-user-3-line"></i>
                                        </span>

                                        <input
                                            type="text"
                                            id="fullname"
                                            name="fullName"
                                            class="form-control"
                                            placeholder="Enter your full name"
                                            autocomplete="name"
                                            required
                                        >

                                    </div>

                                </div>

                                <div class="mb-4">

                                    <label
                                        for="email"
                                        class="form-label fw-semibold"
                                    >
                                        Email Address
                                    </label>

                                    <div class="input-group input-group-lg">

                                        <span class="input-group-text bg-white auth-icon-box">
                                            <i class="ri-mail-line"></i>
                                        </span>

                                        <input
                                            type="email"
                                            id="email"
                                            name="email"
                                            class="form-control"
                                            placeholder="Enter your email"
                                            autocomplete="email"
                                            required
                                        >

                                    </div>

                                </div>

                                <div class="mb-4">

                                    <label
                                        for="password"
                                        class="form-label fw-semibold"
                                    >
                                        Password
                                    </label>

                                    <div class="input-group input-group-lg">

                                        <span class="input-group-text bg-white auth-icon-box">
                                            <i class="ri-lock-line"></i>
                                        </span>

                                        <input
                                            type="password"
                                            id="password"
                                            name="password"
                                            class="form-control"
                                            placeholder="Enter your password"
                                            autocomplete="new-password"
                                            minlength="6"
                                            required
                                        >

                                        <button
                                            type="button"
                                            class="btn btn-outline-secondary password-toggle"
                                            onclick="toggleRegisterPassword()"
                                        >
                                            Show
                                        </button>

                                    </div>

                                    <div class="form-text mt-2">
                                        Password must contain at least 6 characters.
                                    </div>

                                </div>

                                <div class="d-grid">

                                    <button
                                        type="submit"
                                        class="btn btn-warning btn-lg fw-bold py-3"
                                    >
                                        Create Account
                                    </button>

                                </div>

                            </form>

                            <div class="position-relative my-4">

                                <hr>

                                <span
                                    class="position-absolute top-50 start-50 translate-middle bg-white px-3 text-muted text-center"
                                >
                                    Already registered?
                                </span>

                            </div>

                            <div class="d-grid">

                                <a
                                    href="/login"
                                    class="btn btn-outline-dark btn-lg py-3"
                                >
                                    Login to your account
                                </a>

                            </div>

                        </div>

                    </div>

                    <p class="text-center text-muted small mt-4">
                        By creating an account, you agree to the Scatch Store terms and policies.
                    </p>

                </div>

            </div>

        </div>

    </div>

</div>

<script>

    function toggleRegisterPassword() {

        const password =
            document.getElementById("password");

        const button =
            event.currentTarget;

        if (password.type === "password") {

            password.type = "text";
            button.textContent = "Hide";

        } else {

            password.type = "password";
            button.textContent = "Show";

        }

    }

</script>

<%- include("./partials/footer") %>